{
  "name": "xp-bar",
  "version": "1.0.0",
  "description": "A decorative XP bar for your desktop.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder -w"
  },
  "build": {
    "appId": "com.github.gititup.xpbar",
    "productName": "Git XP Bar",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "portable"
      ],
      "icon": "icon.png"
    }
  },
  "keywords": [],
  "author": "GitItUp",
  "license": "ISC",
  "devDependencies": {
    "electron": "^30.5.1",
    "electron-builder": "^26.8.1"
  }
}
