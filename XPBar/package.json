{
  "name": "git-it-up",
  "version": "0.4.5",
  "description": "A progress-tracking desktop overlay for developers.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder -w"
  },
  "build": {
    "appId": "com.github.gititup.app",
    "productName": "GitItUp",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "portable"
      ],
      "icon": "GitItUpLogo.ico"
    }
  },
  "keywords": [],
  "author": "GitItUp",
  "license": "ISC",
  "devDependencies": {
    "electron": "^30.5.1",
    "electron-builder": "^26.8.1"
  }
}